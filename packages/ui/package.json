{
  "name": "@acronis-platform/shadcn-uikit",
  "version": "0.34.0",
  "description": "Acronis shadcn UI component library built with TypeScript, following shadcn design principles",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./styles": "./dist/shadcn-uikit.css",
    "./styles/full": "./dist/shadcn-uikit-full.css",
    "./styles/tokens": "./dist/tokens.css",
    "./styles/base": "./dist/base.css",
    "./styles/components": "./dist/components.css",
    "./styles/utilities": "./dist/utilities.css",
    "./styles/themes": "./dist/themes/acronis-default.css",
    "./styles/themes/acronis-default": "./dist/themes/acronis-default.css",
    "./styles/themes/acronis-ocean": "./dist/themes/acronis-ocean.css",
    "./styles/themes/cyber-chat": "./dist/themes/cyber-chat.css",
    "./styles/themes/acronis-white-label": "./dist/themes/acronis-white-label.css",
    "./tailwind-preset": {
      "import": "./tailwind.preset.js",
      "types": "./tailwind.preset.d.ts",
      "require": "./tailwind.preset.js"
    },
    "./components/*": "./dist/components/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "tailwind.preset.js",
    "tailwind.preset.d.ts"
  ],
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:full-css && pnpm run build:llms",
    "build:full-css": "tsx scripts/build-full-css.ts",
    "build:lib": "vite build",
    "build:types": "tsc --project tsconfig.build.json",
    "build:llms": "tsx scripts/generate-llms-txt.ts",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "generate:icon-stories": "tsx scripts/generate-icon-stories.ts",
    "generate:themes": "tsx scripts/generate-white-label-themes.ts",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:test:visual": "test-storybook",
    "storybook:test:visual:update": "test-storybook --updateSnapshot",
    "storybook:test:visual:docker": "docker compose -f ../../docker-compose.storybook.yml up --build --abort-on-container-exit --exit-code-from test-runner",
    "storybook:test:visual:docker:update": "docker compose -f ../../docker-compose.storybook.yml -f ../../docker-compose.storybook.update.yml up --build --abort-on-container-exit --exit-code-from test-runner"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "tw-animate-css": {
      "optional": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "culori": "^4.0.2",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.72.1",
    "react-resizable-panels": "^4.9.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@storybook/addon-a11y": "10.3.4",
    "@storybook/addon-docs": "10.3.4",
    "@storybook/addon-links": "10.3.4",
    "@storybook/addon-vitest": "10.3.4",
    "@storybook/react": "10.3.4",
    "@storybook/test": "8.6.18",
    "@storybook/react-vite": "10.3.4",
    "@storybook/test-runner": "0.24.3",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.5.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.2",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "eslint": "10.1.0",
    "happy-dom": "20.8.9",
    "http-server": "^14.1.1",
    "jest-image-snapshot": "6.5.2",
    "postcss": "^8.5.8",
    "sass-embedded": "1.99.0",
    "storybook": "^10.3.4",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.3.0",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "4.1.2"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "shadcn",
    "typescript",
    "uikit",
    "multi-framework",
    "acronis"
  ],
  "author": "Acronis International GmbH",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
